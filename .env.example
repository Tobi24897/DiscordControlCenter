# Discord user token (Discord im Browser -> F12 -> Network -> beliebiger Request an discord.com -> Request Header "Authorization")
DISCORD_TOKEN=

# Port des lokalen Webservers
SERVER_PORT=8020

# Sekunden zwischen Poll-Zyklen (auch live im Settings-UI aenderbar)
POLL_INTERVAL=15

# 1 = Browser beim Start nicht automatisch oeffnen
NO_BROWSER=
